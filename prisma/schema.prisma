// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMINISTRATOR
  MANAGER
  SUPERVISOR
  EMPLOYEE
}

enum EmploymentType {
  CASUAL
  CONTRACTED
}

enum ShiftStatus {
  DRAFT
  PUBLISHED
}

enum LeaveType {
  ANNUAL
  SICK
  COMPASSIONATE
  MATERNITY
  TRAINING
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model User {
  id        String    @id @default(cuid())
  clerkId   String    @unique
  email     String    @unique
  role      Role      @default(EMPLOYEE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  employee  Employee?
}

model Employee {
  id     String  @id @default(cuid())
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId String? @unique

  firstName String
  lastName  String
  email     String

  phone                 String?
  emergencyContactName  String?
  emergencyContactPhone String?

  employmentType EmploymentType
  department     String
  contractHours  Decimal? @db.Decimal(5, 2)
  payRate        Decimal? @db.Decimal(8, 2)

  manager   Employee?  @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  managerId String?
  reports   Employee[] @relation("EmployeeManager")

  archivedAt DateTime?

  shifts                Shift[]
  shiftsCreated         Shift[]        @relation("ShiftCreatedBy")
  leaveRequests         LeaveRequest[]
  leaveRequestsReviewed LeaveRequest[] @relation("LeaveReviewedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([managerId])
}

model Shift {
  id         String   @id @default(cuid())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  employeeId String

  date      DateTime
  startTime DateTime
  endTime   DateTime

  department String
  status     ShiftStatus @default(DRAFT)

  createdBy   Employee? @relation("ShiftCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([date])
}

model LeaveRequest {
  id String @id @default(cuid())

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  employeeId String

  leaveType LeaveType
  startDate DateTime
  endDate   DateTime
  reason    String?

  status      LeaveStatus @default(PENDING)
  requestedAt DateTime    @default(now())

  reviewedBy   Employee? @relation("LeaveReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedById String?
  reviewedAt   DateTime?
  reviewNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
}
